# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados (PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/agendamento

# Autenticação
JWT_SECRET=troque_por_uma_chave_secreta_forte
JWT_EXPIRES_IN=7d

# Fuso horário da aplicação
APP_TIMEZONE=America/Sao_Paulo

# Notificações WhatsApp — provider: mock | twilio | meta
WHATSAPP_PROVIDER=mock

# Twilio (quando WHATSAPP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp Cloud API / Meta (quando WHATSAPP_PROVIDER=meta)
# META_WHATSAPP_TOKEN=
# META_PHONE_NUMBER_ID=
