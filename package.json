{
  "name": "sistema-agendamento",
  "version": "1.0.0",
  "description": "Sistema de Agendamento com Dashboard",
  "type": "module",
  "main": "src/server/index.js",
  "scripts": {
    "dev": "node --watch src/server/index.js",
    "start": "node src/database/migrate.js && node src/server/index.js",
    "build": "npm install --prefix src/client --include=dev && npm run build --prefix src/client",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "test": "node --import ./tests/env.js --test --test-concurrency=1 tests/*.test.js"
  },
  "keywords": [
    "agendamento",
    "dashboard",
    "express",
    "postgresql"
  ],
  "author": "Arthur Cesar Dev",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
